---
import Layout from "../../layouts/Layout.astro";
---

<Layout
    title="Contact Us - Date Calculator Tools"
    description="Have questions, suggestions, or feedback about our date calculators? Get in touch with our team."
>
    <div class="mx-auto max-w-xl px-4 py-16 sm:px-6 lg:px-8">
        <div class="text-center">
            <h1 class="text-4xl font-extrabold text-slate-900 tracking-tight">
                Contact Us
            </h1>
            <p class="mt-4 text-base text-slate-500">
                Have comments, bug reports, or feature ideas? We would love to
                hear from you.
            </p>
        </div>

        <div
            class="mt-12 bg-white border border-slate-200 rounded-2xl p-6 sm:p-8 shadow-sm"
        >
            <h2 class="text-lg font-bold text-slate-900 mb-6">
                Send Us Feedback
            </h2>

            <form id="contact-form" class="space-y-6">
                <div>
                    <label
                        for="name"
                        class="block text-sm font-semibold text-slate-700 mb-2"
                        >Name</label
                    >
                    <input
                        type="text"
                        id="name"
                        name="name"
                        placeholder="John Doe"
                        class="block w-full rounded-xl border border-slate-300 px-4 py-3 text-slate-900 shadow-xs focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm"
                        required
                    />
                </div>

                <div>
                    <label
                        for="email"
                        class="block text-sm font-semibold text-slate-700 mb-2"
                        >Email Address</label
                    >
                    <input
                        type="email"
                        id="email"
                        name="email"
                        placeholder="john@example.com"
                        class="block w-full rounded-xl border border-slate-300 px-4 py-3 text-slate-900 shadow-xs focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm"
                        required
                    />
                </div>

                <div>
                    <label
                        for="message"
                        class="block text-sm font-semibold text-slate-700 mb-2"
                        >Message</label
                    >
                    <textarea
                        id="message"
                        name="message"
                        rows="4"
                        placeholder="What feature would you like to see next? Or what can we improve?"
                        class="block w-full rounded-xl border border-slate-300 px-4 py-3 text-slate-900 shadow-xs focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm"
                        required></textarea>
                </div>

                <button
                    type="submit"
                    class="w-full rounded-xl bg-indigo-600 px-5 py-3.5 text-center text-sm font-bold text-white shadow-xs hover:bg-indigo-500 active:bg-indigo-700 transition-colors"
                >
                    Submit Feedback
                </button>
            </form>

            <div
                id="contact-success"
                class="hidden mt-6 rounded-xl bg-green-50 border border-green-200 p-4 text-center"
            >
                <p class="text-sm font-semibold text-green-800">
                    Thank you! Your feedback has been received.
                </p>
            </div>
        </div>

        <!-- Direct Email alternative -->
        <div class="mt-8 text-center text-sm text-slate-500">
            <p>Or reach out directly via email at:</p>
            <a
                href="mailto:support@datecalculatortools.com"
                class="mt-2 inline-block font-mono-custom font-bold text-indigo-600 hover:underline"
            >
                support@datecalculatortools.com
            </a>
        </div>
    </div>
</Layout>

<script>
    const form = document.getElementById("contact-form") as HTMLFormElement;
    const successMsg = document.getElementById(
        "contact-success",
    ) as HTMLDivElement;

    if (form && successMsg) {
        form.addEventListener("submit", (e) => {
            e.preventDefault();
            // Since it's static deployment, simulate success
            successMsg.classList.remove("hidden");
            form.reset();

            setTimeout(() => {
                successMsg.classList.add("hidden");
            }, 5000);
        });
    }
</script>
