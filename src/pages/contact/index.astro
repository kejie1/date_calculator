---
import Layout from "../../layouts/Layout.astro";
---

<Layout
    title="Contact Us - Date Calculator Tools"
    description="Have questions, suggestions, or feedback about our date calculators? Contact Date Calculator Tools by email."
>
    <div class="mx-auto max-w-3xl px-4 py-16 sm:px-6 lg:px-8">
        <div class="text-center">
            <h1 class="text-4xl font-extrabold text-slate-900 tracking-tight">
                Contact Us
            </h1>
            <p class="mt-4 text-base text-slate-500">
                Have comments, bug reports, or feature ideas? Email us directly
                and we will review your message.
            </p>
        </div>

        <div class="mt-12 grid gap-6 md:grid-cols-2">
            <div
                class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm"
            >
                <h2 class="text-lg font-bold text-slate-900">
                    General Support
                </h2>
                <p class="mt-3 text-sm leading-6 text-slate-500">
                    Use this address for calculator feedback, bug reports,
                    feature suggestions, and general questions.
                </p>
                <a
                    href="mailto:support@datecalculatortools.com"
                    class="mt-5 inline-block font-mono-custom text-sm font-bold text-indigo-600 hover:underline"
                >
                    support@datecalculatortools.com
                </a>
            </div>

            <div
                class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm"
            >
                <h2 class="text-lg font-bold text-slate-900">
                    Privacy Questions
                </h2>
                <p class="mt-3 text-sm leading-6 text-slate-500">
                    Use this address for privacy policy questions or requests
                    related to data handling.
                </p>
                <a
                    href="mailto:privacy@datecalculatortools.com"
                    class="mt-5 inline-block font-mono-custom text-sm font-bold text-indigo-600 hover:underline"
                >
                    privacy@datecalculatortools.com
                </a>
            </div>
        </div>

        <div
            class="mt-8 rounded-2xl border border-amber-200 bg-amber-50 p-5 text-sm leading-6 text-amber-900"
        >
            Please do not include private business schedules, personal
            identifiers, passwords, or sensitive documents in support emails.
            The calculators run locally in your browser, and email should only
            be used for general feedback or support requests.
        </div>
    </div>
</Layout>
