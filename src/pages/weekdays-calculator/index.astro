---
import Layout from "../../layouts/Layout.astro";
---

<Layout
    title="Weekdays Calculator - Count Weekday Occurrences"
    description="Calculate the exact occurrences of Mondays, Tuesdays, Wednesdays, Thursdays, Fridays, Saturdays, and Sundays between two dates."
>
    <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
        <!-- Breadcrumb -->
        <nav
            class="flex mb-8 text-sm font-medium text-slate-500"
            aria-label="Breadcrumb"
        >
            <ol class="inline-flex items-center space-x-1 md:space-x-3">
                <li class="inline-flex items-center">
                    <a href="/" class="hover:text-indigo-600 transition-colors"
                        >Home</a
                    >
                </li>
                <li>
                    <div class="flex items-center">
                        <svg
                            class="w-3 h-3 text-slate-400 mx-1"
                            aria-hidden="true"
                            xmlns="http://www.w3.org/2000/svg"
                            fill="none"
                            viewBox="0 0 6 10"
                        >
                            <path
                                stroke="currentColor"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="m1 9 4-4-4-4"></path>
                        </svg>
                        <span class="text-slate-400 ml-1 md:ml-2"
                            >Weekdays Calculator</span
                        >
                    </div>
                </li>
            </ol>
        </nav>

        <!-- H1 Header -->
        <div class="border-b border-slate-200 pb-5 mb-8">
            <h1
                class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl"
            >
                Weekdays Calculator
            </h1>
            <p class="mt-2 text-base text-slate-500">
                Calculate the exact number of standard working days and the
                individual count of each weekday (e.g. number of Tuesdays)
                between two dates.
            </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
            <!-- Calculator Column -->
            <div
                class="lg:col-span-7 bg-white rounded-2xl border border-slate-200 p-6 sm:p-8 shadow-sm"
            >
                <form id="calc-form" class="space-y-6">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                        <div>
                            <label
                                for="start-date"
                                class="block text-sm font-bold text-slate-700 mb-2"
                                >Start Date</label
                            >
                            <input
                                type="date"
                                id="start-date"
                                name="start-date"
                                class="block w-full rounded-xl border border-slate-300 px-4 py-3 text-slate-900 shadow-xs focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm"
                                required
                            />
                        </div>
                        <div>
                            <label
                                for="end-date"
                                class="block text-sm font-bold text-slate-700 mb-2"
                                >End Date</label
                            >
                            <input
                                type="date"
                                id="end-date"
                                name="end-date"
                                class="block w-full rounded-xl border border-slate-300 px-4 py-3 text-slate-900 shadow-xs focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm"
                                required
                            />
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="flex flex-wrap gap-3 pt-2">
                        <button
                            type="submit"
                            class="flex-1 min-w-[120px] rounded-xl bg-indigo-600 px-5 py-3 text-center text-sm font-bold text-white shadow-xs hover:bg-indigo-500 active:bg-indigo-700 transition-colors"
                        >
                            Analyze Weekdays
                        </button>
                        <button
                            type="button"
                            id="btn-example"
                            class="rounded-xl border border-slate-200 bg-slate-50 px-5 py-3 text-sm font-semibold text-slate-700 hover:bg-slate-100 active:bg-slate-200 transition-colors"
                        >
                            Load Example
                        </button>
                        <button
                            type="button"
                            id="btn-clear"
                            class="rounded-xl border border-slate-200 bg-white px-5 py-3 text-sm font-semibold text-slate-500 hover:text-slate-700 hover:bg-slate-50 transition-colors"
                        >
                            Clear
                        </button>
                    </div>
                </form>

                <!-- Results Block -->
                <div
                    id="results-block"
                    class="hidden mt-8 border-t border-slate-100 pt-8 space-y-6"
                >
                    <div class="flex items-center justify-between">
                        <h2 class="text-lg font-bold text-slate-900">
                            Calculated Weekday Breakdown
                        </h2>
                        <button
                            type="button"
                            id="btn-copy"
                            class="inline-flex items-center gap-1 text-xs font-semibold text-indigo-600 hover:text-indigo-500 border border-indigo-100 bg-indigo-50/50 hover:bg-indigo-50 px-2.5 py-1.5 rounded-lg transition-colors"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke-width="1.5"
                                stroke="currentColor"
                                class="w-3.5 h-3.5"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 0 1-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H5.25m11.9-3.664A2.251 2.251 0 0 0 15 2.25h-1.5a2.251 2.251 0 0 0-2.15 1.586m5.8 0c.065.21.1.433.1.664v.75h-6V4.5c0-.231.035-.454.1-.664M6.75 7.5H4.875c-.621 0-1.125.504-1.125 1.125v12c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V16.5a9 9 0 0 0-9-9Z"
                                ></path>
                            </svg>
                            <span>Copy results</span>
                        </button>
                    </div>

                    <!-- Working Days Summary -->
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div
                            class="rounded-xl bg-indigo-50/50 p-4 border border-indigo-100"
                        >
                            <span
                                class="block text-xs font-semibold text-indigo-600 uppercase tracking-wider"
                                >Total Workdays (Mon - Fri)</span
                            >
                            <span
                                id="res-total-workdays"
                                class="block mt-1 text-2xl font-extrabold text-indigo-950 font-mono-custom"
                                >-</span
                            >
                        </div>

                        <div
                            class="rounded-xl bg-slate-50 p-4 border border-slate-100"
                        >
                            <span
                                class="block text-xs font-semibold text-slate-500 uppercase tracking-wider"
                                >Total Weekend Days</span
                            >
                            <span
                                id="res-total-weekends"
                                class="block mt-1 text-2xl font-extrabold text-slate-800 font-mono-custom"
                                >-</span
                            >
                        </div>
                    </div>

                    <!-- Individual weekday grid -->
                    <div
                        class="border border-slate-200/60 rounded-xl overflow-hidden bg-slate-50 p-4"
                    >
                        <span
                            class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-4"
                            >Occurrences of each Weekday</span
                        >

                        <div class="grid grid-cols-2 sm:grid-cols-7 gap-2">
                            <div
                                class="bg-white p-3 rounded-lg border border-slate-100 text-center shadow-xs"
                            >
                                <span
                                    class="block text-xs font-bold text-slate-400"
                                    >Mon</span
                                >
                                <span
                                    id="res-mon"
                                    class="block mt-1 text-lg font-extrabold text-slate-800 font-mono-custom"
                                    >-</span
                                >
                            </div>
                            <div
                                class="bg-white p-3 rounded-lg border border-slate-100 text-center shadow-xs"
                            >
                                <span
                                    class="block text-xs font-bold text-slate-400"
                                    >Tue</span
                                >
                                <span
                                    id="res-tue"
                                    class="block mt-1 text-lg font-extrabold text-slate-800 font-mono-custom"
                                    >-</span
                                >
                            </div>
                            <div
                                class="bg-white p-3 rounded-lg border border-slate-100 text-center shadow-xs"
                            >
                                <span
                                    class="block text-xs font-bold text-slate-400"
                                    >Wed</span
                                >
                                <span
                                    id="res-wed"
                                    class="block mt-1 text-lg font-extrabold text-slate-800 font-mono-custom"
                                    >-</span
                                >
                            </div>
                            <div
                                class="bg-white p-3 rounded-lg border border-slate-100 text-center shadow-xs"
                            >
                                <span
                                    class="block text-xs font-bold text-slate-400"
                                    >Thu</span
                                >
                                <span
                                    id="res-thu"
                                    class="block mt-1 text-lg font-extrabold text-slate-800 font-mono-custom"
                                    >-</span
                                >
                            </div>
                            <div
                                class="bg-white p-3 rounded-lg border border-slate-100 text-center shadow-xs"
                            >
                                <span
                                    class="block text-xs font-bold text-slate-400"
                                    >Fri</span
                                >
                                <span
                                    id="res-fri"
                                    class="block mt-1 text-lg font-extrabold text-slate-800 font-mono-custom"
                                    >-</span
                                >
                            </div>
                            <div
                                class="bg-white p-3 rounded-lg border border-slate-100 text-center shadow-xs bg-amber-50/20 border-amber-100/50"
                            >
                                <span
                                    class="block text-xs font-bold text-amber-500/80"
                                    >Sat</span
                                >
                                <span
                                    id="res-sat"
                                    class="block mt-1 text-lg font-extrabold text-slate-800 font-mono-custom"
                                    >-</span
                                >
                            </div>
                            <div
                                class="bg-white p-3 rounded-lg border border-slate-100 text-center shadow-xs bg-amber-50/20 border-amber-100/50"
                            >
                                <span
                                    class="block text-xs font-bold text-amber-500/80"
                                    >Sun</span
                                >
                                <span
                                    id="res-sun"
                                    class="block mt-1 text-lg font-extrabold text-slate-800 font-mono-custom"
                                    >-</span
                                >
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Information Column -->
            <div class="lg:col-span-5 space-y-8">
                <!-- How to use -->
                <div
                    class="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm"
                >
                    <h2 class="text-lg font-bold text-slate-900 mb-4">
                        Why Count Specific Weekdays?
                    </h2>
                    <p class="text-sm text-slate-600 leading-relaxed mb-3">
                        Counting the frequency of individual weekdays is crucial
                        for scheduling recurring operational processes, such as:
                    </p>
                    <ul
                        class="space-y-2 text-sm text-slate-600 list-disc list-inside"
                    >
                        <li>
                            <strong>Weekly Meetings:</strong> Know exactly how many
                            Mondays exist in a quarter for status alignment.
                        </li>
                        <li>
                            <strong>Logistics Shipping:</strong> Track recurring Wednesday
                            dispatch batches over several months.
                        </li>
                        <li>
                            <strong>Retail Planning:</strong> Forecast checkout traffic
                            by knowing the exact count of Saturdays and Sundays in
                            a month.
                        </li>
                    </ul>
                </div>

                <!-- Example -->
                <div
                    class="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm"
                >
                    <h2 class="text-lg font-bold text-slate-900 mb-3">
                        Weekday Count Example
                    </h2>
                    <p class="text-sm text-slate-600 leading-relaxed">
                        Between <strong>June 1, 2026</strong> and <strong
                            >June 15, 2026</strong
                        > (excluding the end date):
                    </p>
                    <ul
                        class="mt-2 space-y-1 text-sm text-slate-600 list-disc list-inside"
                    >
                        <li>
                            Total workdays (Mon-Fri): <strong>10 days</strong>
                        </li>
                        <li>
                            Total weekend days (Sat-Sun): <strong
                                >4 days</strong>
                        </li>
                        <li>
                            Mondays: <strong>2</strong>, Tuesdays: <strong
                                >2</strong
                            >, Wednesdays: <strong>2</strong>, Thursdays: <strong
                                >2</strong
                            >, Fridays: <strong>2</strong>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Frequently Asked Questions -->
        <section class="mt-16 border-t border-slate-200 pt-16">
            <h2 class="text-2xl font-bold tracking-tight text-slate-900 mb-8">
                Frequently Asked Questions
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div>
                    <h3 class="text-base font-bold text-slate-900 mb-2">
                        How are the start and end dates inclusive or exclusive?
                    </h3>
                    <p class="text-sm text-slate-600 leading-relaxed">
                        By default, this tool performs standard exclusive day
                        counting (the starting date itself is counted, but the
                        end date is not). This represents standard duration
                        spacing.
                    </p>
                </div>
                <div>
                    <h3 class="text-base font-bold text-slate-900 mb-2">
                        Can this tool analyze leap years?
                    </h3>
                    <p class="text-sm text-slate-600 leading-relaxed">
                        Absolutely. Since the tool queries standard calendar
                        date steps dynamically on the local browser engine, leap
                        days are respected correctly (e.g. February 29, 2028 is
                        correctly analyzed as a Tuesday).
                    </p>
                </div>
                <div>
                    <h3 class="text-base font-bold text-slate-900 mb-2">
                        Are calculations private?
                    </h3>
                    <p class="text-sm text-slate-600 leading-relaxed">
                        Yes. No database, server, or API processes are involved
                        in any of our calculations. Your selected dates are
                        processed in standard memory on your computer, ensuring
                        total data safety.
                    </p>
                </div>
                <div>
                    <h3 class="text-base font-bold text-slate-900 mb-2">
                        What if the start date is later than the end date?
                    </h3>
                    <p class="text-sm text-slate-600 leading-relaxed">
                        The results will output negative occurrence numbers,
                        indicating that the count is tracking backward in time.
                    </p>
                </div>
            </div>
        </section>

        <!-- Related Tools Link -->
        <section
            class="mt-16 bg-slate-50 border border-slate-200/80 rounded-2xl p-8"
        >
            <h2 class="text-lg font-bold text-slate-900 mb-4">
                Related Calculators
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                <a
                    href="/business-days-calculator/"
                    class="flex items-center justify-between rounded-xl border border-slate-200 bg-white px-5 py-4 text-sm font-semibold text-slate-700 hover:text-indigo-600 hover:border-indigo-100 transition-all shadow-xs"
                >
                    <span>Business Days Calculator</span>
                    <span>&rarr;</span>
                </a>
                <a
                    href="/date-calculator/"
                    class="flex items-center justify-between rounded-xl border border-slate-200 bg-white px-5 py-4 text-sm font-semibold text-slate-700 hover:text-indigo-600 hover:border-indigo-100 transition-all shadow-xs"
                >
                    <span>Date Calculator</span>
                    <span>&rarr;</span>
                </a>
                <a
                    href="/date-duration-calculator/"
                    class="flex items-center justify-between rounded-xl border border-slate-200 bg-white px-5 py-4 text-sm font-semibold text-slate-700 hover:text-indigo-600 hover:border-indigo-100 transition-all shadow-xs"
                >
                    <span>Date Duration Calculator</span>
                    <span>&rarr;</span>
                </a>
            </div>
        </section>
    </div>
</Layout>

<script>
    const form = document.getElementById("calc-form") as HTMLFormElement;
    const startDateInput = document.getElementById(
        "start-date",
    ) as HTMLInputElement;
    const endDateInput = document.getElementById(
        "end-date",
    ) as HTMLInputElement;
    const resultsBlock = document.getElementById(
        "results-block",
    ) as HTMLDivElement;

    const resTotalWorkdays = document.getElementById(
        "res-total-workdays",
    ) as HTMLSpanElement;
    const resTotalWeekends = document.getElementById(
        "res-total-weekends",
    ) as HTMLSpanElement;

    const resMon = document.getElementById("res-mon") as HTMLSpanElement;
    const resTue = document.getElementById("res-tue") as HTMLSpanElement;
    const resWed = document.getElementById("res-wed") as HTMLSpanElement;
    const resThu = document.getElementById("res-thu") as HTMLSpanElement;
    const resFri = document.getElementById("res-fri") as HTMLSpanElement;
    const resSat = document.getElementById("res-sat") as HTMLSpanElement;
    const resSun = document.getElementById("res-sun") as HTMLSpanElement;

    const btnExample = document.getElementById(
        "btn-example",
    ) as HTMLButtonElement;
    const btnClear = document.getElementById("btn-clear") as HTMLButtonElement;
    const btnCopy = document.getElementById("btn-copy") as HTMLButtonElement;

    function parseLocalDate(dateStr: string): Date {
        const [year, month, day] = dateStr.split("-").map(Number);
        return new Date(year, month - 1, day);
    }

    function calculate() {
        if (!startDateInput.value || !endDateInput.value) return;

        const start = parseLocalDate(startDateInput.value);
        const end = parseLocalDate(endDateInput.value);

        const isReversed = end.getTime() < start.getTime();

        const d1 = new Date(isReversed ? end : start);
        const d2 = new Date(isReversed ? start : end);

        // Occurrences container
        const weekdayCounts = [0, 0, 0, 0, 0, 0, 0]; // 0=Sunday, 1=Monday ... 6=Saturday

        const current = new Date(d1);
        while (current.getTime() < d2.getTime()) {
            const dayOfWeek = current.getDay();
            weekdayCounts[dayOfWeek]++;
            current.setDate(current.getDate() + 1);
        }

        const sign = isReversed ? -1 : 1;

        // Output mapped values
        const mon = weekdayCounts[1] * sign;
        const tue = weekdayCounts[2] * sign;
        const wed = weekdayCounts[3] * sign;
        const thu = weekdayCounts[4] * sign;
        const fri = weekdayCounts[5] * sign;
        const sat = weekdayCounts[6] * sign;
        const sun = weekdayCounts[0] * sign;

        const totalWorkdays = mon + tue + wed + thu + fri;
        const totalWeekends = sat + sun;

        resTotalWorkdays.textContent = `${totalWorkdays.toLocaleString()} day${Math.abs(totalWorkdays) !== 1 ? "s" : ""}`;
        resTotalWeekends.textContent = `${totalWeekends.toLocaleString()} day${Math.abs(totalWeekends) !== 1 ? "s" : ""}`;

        resMon.textContent = String(mon);
        resTue.textContent = String(tue);
        resWed.textContent = String(wed);
        resThu.textContent = String(thu);
        resFri.textContent = String(fri);
        resSat.textContent = String(sat);
        resSun.textContent = String(sun);

        resultsBlock.classList.remove("hidden");
    }

    form.addEventListener("submit", (e) => {
        e.preventDefault();
        calculate();
    });

    btnExample.addEventListener("click", () => {
        const today = new Date();
        const future = new Date();
        future.setDate(today.getDate() + 28); // Exactly 4 weeks

        const formatDate = (d: Date) => {
            const year = d.getFullYear();
            const month = String(d.getMonth() + 1).padStart(2, "0");
            const day = String(d.getDate()).padStart(2, "0");
            return `${year}-${month}-${day}`;
        };

        startDateInput.value = formatDate(today);
        endDateInput.value = formatDate(future);
        calculate();
    });

    btnClear.addEventListener("click", () => {
        form.reset();
        resultsBlock.classList.add("hidden");
    });

    btnCopy.addEventListener("click", () => {
        const textToCopy = `Calculation Results:
- Start Date: ${startDateInput.value}
- End Date: ${endDateInput.value}
- Total Workdays: ${resTotalWorkdays.textContent}
- Total Weekends: ${resTotalWeekends.textContent}
- Mondays: ${resMon.textContent}
- Tuesdays: ${resTue.textContent}
- Wednesdays: ${resWed.textContent}
- Thursdays: ${resThu.textContent}
- Fridays: ${resFri.textContent}
- Saturdays: ${resSat.textContent}
- Sundays: ${resSun.textContent}`;

        navigator.clipboard.writeText(textToCopy).then(() => {
            const originalText = btnCopy.innerHTML;
            btnCopy.innerHTML = `
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5 text-green-600">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
        </svg>
        <span class="text-green-600">Copied!</span>
      `;
            setTimeout(() => {
                btnCopy.innerHTML = originalText;
            }, 2000);
        });
    });
</script>
