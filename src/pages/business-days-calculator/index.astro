---
import Layout from "../../layouts/Layout.astro";
---

<Layout
    title="Business Days Calculator - Count Working Days"
    description="Calculate the exact number of business days (working days) and weekends between two dates. Customize calculations by including or excluding start/end dates."
>
    <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
        <!-- Breadcrumb -->
        <nav
            class="flex mb-8 text-sm font-medium text-slate-500"
            aria-label="Breadcrumb"
        >
            <ol class="inline-flex items-center space-x-1 md:space-x-3">
                <li class="inline-flex items-center">
                    <a href="/" class="hover:text-indigo-600 transition-colors"
                        >Home</a
                    >
                </li>
                <li>
                    <div class="flex items-center">
                        <svg
                            class="w-3 h-3 text-slate-400 mx-1"
                            aria-hidden="true"
                            xmlns="http://www.w3.org/2000/svg"
                            fill="none"
                            viewBox="0 0 6 10"
                        >
                            <path
                                stroke="currentColor"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="m1 9 4-4-4-4"></path>
                        </svg>
                        <span class="text-slate-400 ml-1 md:ml-2"
                            >Business Days Calculator</span
                        >
                    </div>
                </li>
            </ol>
        </nav>

        <!-- H1 Header -->
        <div class="border-b border-slate-200 pb-5 mb-8">
            <h1
                class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl"
            >
                Business Days Calculator
            </h1>
            <p class="mt-2 text-base text-slate-500">
                Calculate standard business days (Monday-Friday) and weekend
                days between any two dates.
            </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
            <!-- Calculator Column -->
            <div
                class="lg:col-span-7 bg-white rounded-2xl border border-slate-200 p-6 sm:p-8 shadow-sm"
            >
                <!-- Notice Banner -->
                <div
                    class="mb-6 rounded-xl bg-amber-50 border border-amber-200 p-4"
                >
                    <div class="flex">
                        <div class="shrink-0">
                            <svg
                                class="h-5 w-5 text-amber-600"
                                viewBox="0 0 20 20"
                                fill="currentColor"
                                aria-hidden="true"
                            >
                                <path
                                    fill-rule="evenodd"
                                    d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z"
                                    clip-rule="evenodd"></path>
                            </svg>
                        </div>
                        <div class="ml-3 flex-1 md:flex md:justify-between">
                            <p class="text-xs font-semibold text-amber-800">
                                Note: Public holidays are not included in this
                                calculation. Only weekend days (Saturday and
                                Sunday) are excluded.
                            </p>
                        </div>
                    </div>
                </div>

                <form id="calc-form" class="space-y-6">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                        <div>
                            <label
                                for="start-date"
                                class="block text-sm font-bold text-slate-700 mb-2"
                                >Start Date</label
                            >
                            <input
                                type="date"
                                id="start-date"
                                name="start-date"
                                class="block w-full rounded-xl border border-slate-300 px-4 py-3 text-slate-900 shadow-xs focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm"
                                required
                            />
                        </div>
                        <div>
                            <label
                                for="end-date"
                                class="block text-sm font-bold text-slate-700 mb-2"
                                >End Date</label
                            >
                            <input
                                type="date"
                                id="end-date"
                                name="end-date"
                                class="block w-full rounded-xl border border-slate-300 px-4 py-3 text-slate-900 shadow-xs focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm"
                                required
                            />
                        </div>
                    </div>

                    <!-- Configuration options -->
                    <div
                        class="space-y-3 bg-slate-50 p-4 rounded-xl border border-slate-100"
                    >
                        <span
                            class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-2"
                            >Options</span
                        >
                        <div class="flex flex-col gap-2">
                            <label class="relative flex items-start">
                                <div class="flex h-6 items-center">
                                    <input
                                        id="inc-start"
                                        name="inc-start"
                                        type="checkbox"
                                        class="h-4 w-4 rounded-sm border-slate-300 text-indigo-600 focus:ring-indigo-500"
                                    />
                                </div>
                                <div class="ml-3 text-sm leading-6">
                                    <span class="font-semibold text-slate-700"
                                        >Include start date in results</span
                                    >
                                </div>
                            </label>
                            <label class="relative flex items-start">
                                <div class="flex h-6 items-center">
                                    <input
                                        id="inc-end"
                                        name="inc-end"
                                        type="checkbox"
                                        class="h-4 w-4 rounded-sm border-slate-300 text-indigo-600 focus:ring-indigo-500"
                                    />
                                </div>
                                <div class="ml-3 text-sm leading-6">
                                    <span class="font-semibold text-slate-700"
                                        >Include end date in results</span
                                    >
                                </div>
                            </label>
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="flex flex-wrap gap-3 pt-2">
                        <button
                            type="submit"
                            class="flex-1 min-w-[120px] rounded-xl bg-indigo-600 px-5 py-3 text-center text-sm font-bold text-white shadow-xs hover:bg-indigo-500 active:bg-indigo-700 transition-colors"
                        >
                            Calculate
                        </button>
                        <button
                            type="button"
                            id="btn-example"
                            class="rounded-xl border border-slate-200 bg-slate-50 px-5 py-3 text-sm font-semibold text-slate-700 hover:bg-slate-100 active:bg-slate-200 transition-colors"
                        >
                            Load Example
                        </button>
                        <button
                            type="button"
                            id="btn-clear"
                            class="rounded-xl border border-slate-200 bg-white px-5 py-3 text-sm font-semibold text-slate-500 hover:text-slate-700 hover:bg-slate-50 transition-colors"
                        >
                            Clear
                        </button>
                    </div>
                </form>

                <!-- Results Block -->
                <div
                    id="results-block"
                    class="hidden mt-8 border-t border-slate-100 pt-8 space-y-6"
                >
                    <div class="flex items-center justify-between">
                        <h2 class="text-lg font-bold text-slate-900">
                            Calculation Results
                        </h2>
                        <button
                            type="button"
                            id="btn-copy"
                            class="inline-flex items-center gap-1 text-xs font-semibold text-indigo-600 hover:text-indigo-500 border border-indigo-100 bg-indigo-50/50 hover:bg-indigo-50 px-2.5 py-1.5 rounded-lg transition-colors"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke-width="1.5"
                                stroke="currentColor"
                                class="w-3.5 h-3.5"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 0 1-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H5.25m11.9-3.664A2.251 2.251 0 0 0 15 2.25h-1.5a2.251 2.251 0 0 0-2.15 1.586m5.8 0c.065.21.1.433.1.664v.75h-6V4.5c0-.231.035-.454.1-.664M6.75 7.5H4.875c-.621 0-1.125.504-1.125 1.125v12c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V16.5a9 9 0 0 0-9-9Z"
                                ></path>
                            </svg>
                            <span>Copy results</span>
                        </button>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                        <div
                            class="rounded-xl bg-slate-50 p-4 border border-slate-100"
                        >
                            <span
                                class="block text-xs font-medium text-slate-500 uppercase tracking-wider"
                                >Business Days</span
                            >
                            <span
                                id="res-biz-days"
                                class="block mt-1 text-2xl font-extrabold text-indigo-600 font-mono-custom"
                                >-</span
                            >
                            <span class="block mt-1 text-xs text-slate-400"
                                >Monday - Friday</span
                            >
                        </div>

                        <div
                            class="rounded-xl bg-slate-50 p-4 border border-slate-100"
                        >
                            <span
                                class="block text-xs font-medium text-slate-500 uppercase tracking-wider"
                                >Weekend Days</span
                            >
                            <span
                                id="res-wkend-days"
                                class="block mt-1 text-2xl font-extrabold text-slate-800 font-mono-custom"
                                >-</span
                            >
                            <span class="block mt-1 text-xs text-slate-400"
                                >Saturday & Sunday</span
                            >
                        </div>

                        <div
                            class="rounded-xl bg-slate-50 p-4 border border-slate-100"
                        >
                            <span
                                class="block text-xs font-medium text-slate-500 uppercase tracking-wider"
                                >Calendar Days</span
                            >
                            <span
                                id="res-cal-days"
                                class="block mt-1 text-2xl font-extrabold text-slate-800 font-mono-custom"
                                >-</span
                            >
                            <span class="block mt-1 text-xs text-slate-400"
                                >Total days difference</span
                            >
                        </div>
                    </div>
                </div>
            </div>

            <!-- Information Column -->
            <div class="lg:col-span-5 space-y-8">
                <!-- How to use -->
                <div
                    class="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm"
                >
                    <h2 class="text-lg font-bold text-slate-900 mb-4">
                        How Business Days are Counted
                    </h2>
                    <p class="text-sm text-slate-600 leading-relaxed mb-3">
                        A business day is defined as any calendar day from <strong
                            >Monday through Friday</strong
                        >. Saturdays and Sundays are fully excluded.
                    </p>
                    <ul
                        class="space-y-2 text-sm text-slate-600 list-disc list-inside"
                    >
                        <li>
                            <strong>Exclude Start/End:</strong> Standard calculation.
                            (e.g. Wed to next Wed is 5 business days).
                        </li>
                        <li>
                            <strong>Include Start:</strong> Counts the first day as
                            a business day if it is a weekday.
                        </li>
                        <li>
                            <strong>Include End:</strong> Counts the last day as a
                            business day if it is a weekday.
                        </li>
                    </ul>
                </div>

                <!-- Example -->
                <div
                    class="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm"
                >
                    <h2 class="text-lg font-bold text-slate-900 mb-3">
                        Practical Example
                    </h2>
                    <p class="text-sm text-slate-600 leading-relaxed">
                        If you start on <strong>Friday, June 5, 2026</strong> and
                        end on <strong>Monday, June 15, 2026</strong>:
                    </p>
                    <ul
                        class="mt-2 space-y-1 text-sm text-slate-600 list-disc list-inside"
                    >
                        <li>
                            Standard (Exclude Start & End): <strong
                                >5 business days</strong>
                        </li>
                        <li>
                            Include Both Start & End: <strong
                                >7 business days</strong
                            > (since both are weekdays)
                        </li>
                        <li>Total weekend days: <strong>4 days</strong></li>
                        <li>Total calendar days: <strong>10 days</strong></li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Frequently Asked Questions -->
        <section class="mt-16 border-t border-slate-200 pt-16">
            <h2 class="text-2xl font-bold tracking-tight text-slate-900 mb-8">
                Frequently Asked Questions
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div>
                    <h3 class="text-base font-bold text-slate-900 mb-2">
                        Why aren't federal or state holidays included?
                    </h3>
                    <p class="text-sm text-slate-600 leading-relaxed">
                        Holidays differ significantly depending on your
                        geographic location (country, region, or state) and your
                        industry. This initial version does not query a global
                        holidays database to avoid misleading calculations. We
                        plan to introduce customizable holiday lists in a future
                        update.
                    </p>
                </div>
                <div>
                    <h3 class="text-base font-bold text-slate-900 mb-2">
                        How are start and end dates handled?
                    </h3>
                    <p class="text-sm text-slate-600 leading-relaxed">
                        By default, the starting date is not counted (0 business
                        days have passed on day one). Checking the option
                        "Include start date" counts it as a full day of work, as
                        long as it does not fall on a weekend.
                    </p>
                </div>
                <div>
                    <h3 class="text-base font-bold text-slate-900 mb-2">
                        What if my starting date is after my ending date?
                    </h3>
                    <p class="text-sm text-slate-600 leading-relaxed">
                        The calculator will correctly compute the values and
                        return negative numbers, indicating that the duration
                        has passed backwards in time.
                    </p>
                </div>
                <div>
                    <h3 class="text-base font-bold text-slate-900 mb-2">
                        Is the calculation private?
                    </h3>
                    <p class="text-sm text-slate-600 leading-relaxed">
                        Completely. All business day logic runs locally in your
                        browser. No form inputs are transmitted to our servers
                        or stored anywhere.
                    </p>
                </div>
            </div>
        </section>

        <!-- Related Tools Link -->
        <section
            class="mt-16 bg-slate-50 border border-slate-200/80 rounded-2xl p-8"
        >
            <h2 class="text-lg font-bold text-slate-900 mb-4">
                Related Calculators
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                <a
                    href="/date-calculator/"
                    class="flex items-center justify-between rounded-xl border border-slate-200 bg-white px-5 py-4 text-sm font-semibold text-slate-700 hover:text-indigo-600 hover:border-indigo-100 transition-all shadow-xs"
                >
                    <span>Date Calculator</span>
                    <span>&rarr;</span>
                </a>
                <a
                    href="/date-duration-calculator/"
                    class="flex items-center justify-between rounded-xl border border-slate-200 bg-white px-5 py-4 text-sm font-semibold text-slate-700 hover:text-indigo-600 hover:border-indigo-100 transition-all shadow-xs"
                >
                    <span>Date Duration Calculator</span>
                    <span>&rarr;</span>
                </a>
                <a
                    href="/weekdays-calculator/"
                    class="flex items-center justify-between rounded-xl border border-slate-200 bg-white px-5 py-4 text-sm font-semibold text-slate-700 hover:text-indigo-600 hover:border-indigo-100 transition-all shadow-xs"
                >
                    <span>Weekdays Calculator</span>
                    <span>&rarr;</span>
                </a>
            </div>
        </section>
    </div>
</Layout>

<script>
    const form = document.getElementById("calc-form") as HTMLFormElement;
    const startDateInput = document.getElementById(
        "start-date",
    ) as HTMLInputElement;
    const endDateInput = document.getElementById(
        "end-date",
    ) as HTMLInputElement;
    const incStartCheck = document.getElementById(
        "inc-start",
    ) as HTMLInputElement;
    const incEndCheck = document.getElementById("inc-end") as HTMLInputElement;
    const resultsBlock = document.getElementById(
        "results-block",
    ) as HTMLDivElement;

    const resBizDays = document.getElementById(
        "res-biz-days",
    ) as HTMLSpanElement;
    const resWkendDays = document.getElementById(
        "res-wkend-days",
    ) as HTMLSpanElement;
    const resCalDays = document.getElementById(
        "res-cal-days",
    ) as HTMLSpanElement;

    const btnExample = document.getElementById(
        "btn-example",
    ) as HTMLButtonElement;
    const btnClear = document.getElementById("btn-clear") as HTMLButtonElement;
    const btnCopy = document.getElementById("btn-copy") as HTMLButtonElement;

    function parseLocalDate(dateStr: string): Date {
        const [year, month, day] = dateStr.split("-").map(Number);
        return new Date(year, month - 1, day);
    }

    function calculate() {
        if (!startDateInput.value || !endDateInput.value) return;

        const start = parseLocalDate(startDateInput.value);
        const end = parseLocalDate(endDateInput.value);
        const includeStart = incStartCheck.checked;
        const includeEnd = incEndCheck.checked;

        const isReversed = end.getTime() < start.getTime();

        // Sort so start is earlier than end for counting
        const d1 = new Date(isReversed ? end : start);
        const d2 = new Date(isReversed ? start : end);

        let bizDaysCount = 0;
        let weekendDaysCount = 0;
        let totalCalDays = 0;

        // Loop through day by day to perform exact calculation
        const current = new Date(d1);
        const last = new Date(d2);

        // Keep track of which days we visit
        let step = 0;
        const totalSteps = Math.round(
            (last.getTime() - current.getTime()) / (1000 * 60 * 60 * 24),
        );

        while (current.getTime() <= last.getTime()) {
            const isFirstDay = step === 0;
            const isLastDay = step === totalSteps;
            const dayOfWeek = current.getDay(); // 0 is Sunday, 6 is Saturday
            const isWeekend = dayOfWeek === 0 || dayOfWeek === 6;

            let shouldCount = true;

            if (isFirstDay && !includeStart) {
                shouldCount = false;
            }
            if (isLastDay && !includeEnd) {
                shouldCount = false;
            }
            // If start and end date is the same date and neither is included
            if (isFirstDay && isLastDay && !includeStart && !includeEnd) {
                shouldCount = false;
            }

            if (shouldCount) {
                if (isWeekend) {
                    weekendDaysCount++;
                } else {
                    bizDaysCount++;
                }
            }

            current.setDate(current.getDate() + 1);
            step++;
        }

        // Total calendar days
        totalCalDays = totalSteps;
        if (includeStart && includeEnd) {
            totalCalDays = totalSteps + 1;
        } else if (!includeStart && !includeEnd) {
            totalCalDays = Math.max(0, totalSteps - 1);
        } else {
            totalCalDays = totalSteps;
        }

        const sign = isReversed ? -1 : 1;

        // Output results
        resBizDays.textContent = `${(bizDaysCount * sign).toLocaleString()} day${bizDaysCount !== 1 ? "s" : ""}`;
        resWkendDays.textContent = `${(weekendDaysCount * sign).toLocaleString()} day${weekendDaysCount !== 1 ? "s" : ""}`;
        resCalDays.textContent = `${(totalCalDays * sign).toLocaleString()} day${totalCalDays !== 1 ? "s" : ""}`;

        resultsBlock.classList.remove("hidden");
    }

    form.addEventListener("submit", (e) => {
        e.preventDefault();
        calculate();
    });

    btnExample.addEventListener("click", () => {
        // Current date as start date
        const today = new Date();
        const future = new Date();
        future.setDate(today.getDate() + 10); // 10 days in future

        const formatDate = (d: Date) => {
            const year = d.getFullYear();
            const month = String(d.getMonth() + 1).padStart(2, "0");
            const day = String(d.getDate()).padStart(2, "0");
            return `${year}-${month}-${day}`;
        };

        startDateInput.value = formatDate(today);
        endDateInput.value = formatDate(future);
        incStartCheck.checked = false;
        incEndCheck.checked = false;
        calculate();
    });

    btnClear.addEventListener("click", () => {
        form.reset();
        resultsBlock.classList.add("hidden");
    });

    btnCopy.addEventListener("click", () => {
        const textToCopy = `Calculation Results:
- Start Date: ${startDateInput.value}
- End Date: ${endDateInput.value}
- Include Start Date: ${incStartCheck.checked ? "Yes" : "No"}
- Include End Date: ${incEndCheck.checked ? "Yes" : "No"}
- Business Days: ${resBizDays.textContent}
- Weekend Days: ${resWkendDays.textContent}
- Calendar Days: ${resCalDays.textContent}`;

        navigator.clipboard.writeText(textToCopy).then(() => {
            const originalText = btnCopy.innerHTML;
            btnCopy.innerHTML = `
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5 text-green-600">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
        </svg>
        <span class="text-green-600">Copied!</span>
      `;
            setTimeout(() => {
                btnCopy.innerHTML = originalText;
            }, 2000);
        });
    });
</script>
