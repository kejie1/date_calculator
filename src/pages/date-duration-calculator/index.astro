---
import Layout from "../../layouts/Layout.astro";
---

<Layout
    title="Date Duration Calculator | Days Between Dates Breakdown"
    description="Use this date duration calculator to find the exact time between two dates: total days, weeks and days, months, years, and a readable duration summary."
>
    <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
        <!-- Breadcrumb -->
        <nav
            class="flex mb-8 text-sm font-medium text-slate-500"
            aria-label="Breadcrumb"
        >
            <ol class="inline-flex items-center space-x-1 md:space-x-3">
                <li class="inline-flex items-center">
                    <a href="/" class="hover:text-indigo-600 transition-colors"
                        >Home</a
                    >
                </li>
                <li>
                    <div class="flex items-center">
                        <svg
                            class="w-3 h-3 text-slate-400 mx-1"
                            aria-hidden="true"
                            xmlns="http://www.w3.org/2000/svg"
                            fill="none"
                            viewBox="0 0 6 10"
                        >
                            <path
                                stroke="currentColor"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="m1 9 4-4-4-4"></path>
                        </svg>
                        <span class="text-slate-400 ml-1 md:ml-2"
                            >Date Duration Calculator</span
                        >
                    </div>
                </li>
            </ol>
        </nav>

        <!-- H1 Header -->
        <div class="border-b border-slate-200 pb-5 mb-8">
            <h1
                class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl"
            >
                Date Duration Calculator
            </h1>
            <p class="mt-2 text-base text-slate-500">
                Calculate the duration between two dates with total days,
                weeks, approximate months, years, and a human-readable summary.
            </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
            <!-- Calculator Column -->
            <div
                class="lg:col-span-7 bg-white rounded-2xl border border-slate-200 p-6 sm:p-8 shadow-sm"
            >
                <form id="calc-form" class="space-y-6">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                        <div>
                            <label
                                for="start-date"
                                class="block text-sm font-bold text-slate-700 mb-2"
                                >Start Date</label
                            >
                            <input
                                type="date"
                                id="start-date"
                                name="start-date"
                                class="block w-full rounded-xl border border-slate-300 px-4 py-3 text-slate-900 shadow-xs focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm"
                                required
                            />
                        </div>
                        <div>
                            <label
                                for="end-date"
                                class="block text-sm font-bold text-slate-700 mb-2"
                                >End Date</label
                            >
                            <input
                                type="date"
                                id="end-date"
                                name="end-date"
                                class="block w-full rounded-xl border border-slate-300 px-4 py-3 text-slate-900 shadow-xs focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm"
                                required
                            />
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="flex flex-wrap gap-3 pt-2">
                        <button
                            type="submit"
                            class="flex-1 min-w-[120px] rounded-xl bg-indigo-600 px-5 py-3 text-center text-sm font-bold text-white shadow-xs hover:bg-indigo-500 active:bg-indigo-700 transition-colors"
                        >
                            Calculate Date Duration
                        </button>
                        <button
                            type="button"
                            id="btn-example"
                            class="rounded-xl border border-slate-200 bg-slate-50 px-5 py-3 text-sm font-semibold text-slate-700 hover:bg-slate-100 active:bg-slate-200 transition-colors"
                        >
                            Load Example
                        </button>
                        <button
                            type="button"
                            id="btn-clear"
                            class="rounded-xl border border-slate-200 bg-white px-5 py-3 text-sm font-semibold text-slate-500 hover:text-slate-700 hover:bg-slate-50 transition-colors"
                        >
                            Clear
                        </button>
                    </div>
                </form>

                <!-- Results Block -->
                <div
                    id="results-block"
                    class="hidden mt-8 border-t border-slate-100 pt-8 space-y-6"
                >
                    <div class="flex items-center justify-between">
                        <h2 class="text-lg font-bold text-slate-900">
                            Duration Analysis
                        </h2>
                        <button
                            type="button"
                            id="btn-copy"
                            class="inline-flex items-center gap-1 text-xs font-semibold text-indigo-600 hover:text-indigo-500 border border-indigo-100 bg-indigo-50/50 hover:bg-indigo-50 px-2.5 py-1.5 rounded-lg transition-colors"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke-width="1.5"
                                stroke="currentColor"
                                class="w-3.5 h-3.5"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 0 1-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H5.25m11.9-3.664A2.251 2.251 0 0 0 15 2.25h-1.5a2.251 2.251 0 0 0-2.15 1.586m5.8 0c.065.21.1.433.1.664v.75h-6V4.5c0-.231.035-.454.1-.664M6.75 7.5H4.875c-.621 0-1.125.504-1.125 1.125v12c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V16.5a9 9 0 0 0-9-9Z"
                                ></path>
                            </svg>
                            <span>Copy details</span>
                        </button>
                    </div>

                    <!-- Human Sentence Display -->
                    <div
                        class="rounded-xl bg-indigo-50/50 p-5 border border-indigo-100"
                    >
                        <span
                            class="block text-xs font-bold text-indigo-500 uppercase tracking-wider mb-1"
                            >Human Readable Summary</span
                        >
                        <p
                            id="res-sentence"
                            class="text-base sm:text-lg font-semibold text-indigo-950 leading-relaxed"
                        >
                            -
                        </p>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div
                            class="rounded-xl bg-slate-50 p-4 border border-slate-100"
                        >
                            <span
                                class="block text-xs font-medium text-slate-500 uppercase tracking-wider"
                                >Total Days</span
                            >
                            <span
                                id="res-total-days"
                                class="block mt-1 text-2xl font-extrabold text-slate-900 font-mono-custom"
                                >-</span
                            >
                            <span class="block mt-1 text-xs text-slate-400"
                                >Total days between dates</span
                            >
                        </div>

                        <div
                            class="rounded-xl bg-slate-50 p-4 border border-slate-100"
                        >
                            <span
                                class="block text-xs font-medium text-slate-500 uppercase tracking-wider"
                                >Weeks + Days</span
                            >
                            <span
                                id="res-weeks-days"
                                class="block mt-1 text-2xl font-extrabold text-slate-900 font-mono-custom"
                                >-</span
                            >
                            <span class="block mt-1 text-xs text-slate-400"
                                >Broken down by full weeks</span
                            >
                        </div>

                        <div
                            class="rounded-xl bg-slate-50 p-4 border border-slate-100"
                        >
                            <span
                                class="block text-xs font-medium text-slate-500 uppercase tracking-wider"
                                >Approximate Months</span
                            >
                            <span
                                id="res-months"
                                class="block mt-1 text-2xl font-extrabold text-slate-900 font-mono-custom"
                                >-</span
                            >
                            <span class="block mt-1 text-xs text-slate-400"
                                >Using 30.44 days per month avg</span
                            >
                        </div>

                        <div
                            class="rounded-xl bg-slate-50 p-4 border border-slate-100"
                        >
                            <span
                                class="block text-xs font-medium text-slate-500 uppercase tracking-wider"
                                >Approximate Years</span
                            >
                            <span
                                id="res-years"
                                class="block mt-1 text-2xl font-extrabold text-slate-900 font-mono-custom"
                                >-</span
                            >
                            <span class="block mt-1 text-xs text-slate-400"
                                >Using 365.24 days per year avg</span
                            >
                        </div>
                    </div>
                </div>
            </div>

            <!-- Information Column -->
            <div class="lg:col-span-5 space-y-8">
                <!-- How to use -->
                <div
                    class="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm"
                >
                    <h2 class="text-lg font-bold text-slate-900 mb-4">
                        Date Duration and Days Between Dates
                    </h2>
                    <p class="text-sm text-slate-600 leading-relaxed mb-3">
                        This date duration calculator provides
                        multi-perspective statistics so you can review the days
                        between dates in multiple formats:
                    </p>
                    <ul
                        class="space-y-2 text-sm text-slate-600 list-disc list-inside"
                    >
                        <li>
                            <strong>Total Days:</strong> Simple absolute day difference.
                        </li>
                        <li>
                            <strong>Weeks & Days:</strong> Tells you exactly how many
                            completed seven-day segments exist.
                        </li>
                        <li>
                            <strong>Approximate Months:</strong> Calculated using
                            standard calendar length distribution.
                        </li>
                        <li>
                            <strong>Natural Sentence:</strong> Represents exactly
                            how a human would describe the span (e.g., "1 month, 2
                            weeks and 3 days").
                        </li>
                    </ul>
                </div>

                <!-- Example -->
                <div
                    class="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm"
                >
                    <h2 class="text-lg font-bold text-slate-900 mb-3">
                        Duration Example
                    </h2>
                    <p class="text-sm text-slate-600 leading-relaxed">
                        If starting on <strong>January 1, 2026</strong> and ending
                        on <strong>March 15, 2026</strong>:
                    </p>
                    <ul
                        class="mt-2 space-y-1 text-sm text-slate-600 list-disc list-inside"
                    >
                        <li>Total days: <strong>73 calendar days</strong></li>
                        <li>Weeks: <strong>10 weeks and 3 days</strong></li>
                        <li>
                            Human sentence: <strong
                                >2 months, 2 weeks and 0 days</strong>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Frequently Asked Questions -->
        <section class="mt-16 border-t border-slate-200 pt-16">
            <h2 class="text-2xl font-bold tracking-tight text-slate-900 mb-8">
                Frequently Asked Questions
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div>
                    <h3 class="text-base font-bold text-slate-900 mb-2">
                        How do you calculate months precisely?
                    </h3>
                    <p class="text-sm text-slate-600 leading-relaxed">
                        Calendar months vary between 28 and 31 days. The
                        human-readable summary computes exact monthly calendar
                        steps (accounting for correct days in each specific
                        month) rather than relying on a flat average, delivering
                        the most natural result.
                    </p>
                </div>
                <div>
                    <h3 class="text-base font-bold text-slate-900 mb-2">
                        Does the calculation support leap years?
                    </h3>
                    <p class="text-sm text-slate-600 leading-relaxed">
                        Yes. Since the calculation relies on exact calendar
                        math, it respects whether a February contains 28 or 29
                        days during the calculated interval.
                    </p>
                </div>
                <div>
                    <h3 class="text-base font-bold text-slate-900 mb-2">
                        Can this tool count backward in time?
                    </h3>
                    <p class="text-sm text-slate-600 leading-relaxed">
                        Yes. If the end date is prior to the start date, the
                        outputs will show negative values, and the human
                        sentence will end with "ago".
                    </p>
                </div>
                <div>
                    <h3 class="text-base font-bold text-slate-900 mb-2">
                        Are my dates saved on your servers?
                    </h3>
                    <p class="text-sm text-slate-600 leading-relaxed">
                        No. Your privacy is 100% protected. No dates, logs, or
                        analytics regarding your calculations are sent to any
                        remote server.
                    </p>
                </div>
            </div>
        </section>

        <!-- Related Tools Link -->
        <section
            class="mt-16 bg-slate-50 border border-slate-200/80 rounded-2xl p-8"
        >
            <h2 class="text-lg font-bold text-slate-900 mb-4">
                Related Date Calculators
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                <a
                    href="/date-calculator/"
                    class="flex items-center justify-between rounded-xl border border-slate-200 bg-white px-5 py-4 text-sm font-semibold text-slate-700 hover:text-indigo-600 hover:border-indigo-100 transition-all shadow-xs"
                >
                    <span>Calculate Days Between Two Dates</span>
                    <span>&rarr;</span>
                </a>
                <a
                    href="/business-days-calculator/"
                    class="flex items-center justify-between rounded-xl border border-slate-200 bg-white px-5 py-4 text-sm font-semibold text-slate-700 hover:text-indigo-600 hover:border-indigo-100 transition-all shadow-xs"
                >
                    <span>Business Days Calculator</span>
                    <span>&rarr;</span>
                </a>
                <a
                    href="/weekdays-calculator/"
                    class="flex items-center justify-between rounded-xl border border-slate-200 bg-white px-5 py-4 text-sm font-semibold text-slate-700 hover:text-indigo-600 hover:border-indigo-100 transition-all shadow-xs"
                >
                    <span>Weekdays Calculator</span>
                    <span>&rarr;</span>
                </a>
            </div>
        </section>
    </div>
</Layout>

<script>
    const form = document.getElementById("calc-form") as HTMLFormElement;
    const startDateInput = document.getElementById(
        "start-date",
    ) as HTMLInputElement;
    const endDateInput = document.getElementById(
        "end-date",
    ) as HTMLInputElement;
    const resultsBlock = document.getElementById(
        "results-block",
    ) as HTMLDivElement;

    const resSentence = document.getElementById(
        "res-sentence",
    ) as HTMLParagraphElement;
    const resTotalDays = document.getElementById(
        "res-total-days",
    ) as HTMLSpanElement;
    const resWeeksDays = document.getElementById(
        "res-weeks-days",
    ) as HTMLSpanElement;
    const resMonths = document.getElementById("res-months") as HTMLSpanElement;
    const resYears = document.getElementById("res-years") as HTMLSpanElement;

    const btnExample = document.getElementById(
        "btn-example",
    ) as HTMLButtonElement;
    const btnClear = document.getElementById("btn-clear") as HTMLButtonElement;
    const btnCopy = document.getElementById("btn-copy") as HTMLButtonElement;

    function parseLocalDate(dateStr: string): Date {
        const [year, month, day] = dateStr.split("-").map(Number);
        return new Date(year, month - 1, day);
    }

    function getHumanReadableDiff(
        d1: Date,
        d2: Date,
        isReversed: boolean,
    ): string {
        // Exact month, year, and day calendar-step calculator
        let y1 = d1.getFullYear();
        let m1 = d1.getMonth();
        let r1 = d1.getDate();

        let y2 = d2.getFullYear();
        let m2 = d2.getMonth();
        let r2 = d2.getDate();

        let years = y2 - y1;
        let months = m2 - m1;
        let days = r2 - r1;

        if (days < 0) {
            // Borrow days from previous month
            months--;
            // Get days in previous month
            const prevMonth = new Date(y2, m2, 0);
            days += prevMonth.getDate();
        }

        if (months < 0) {
            years--;
            months += 12;
        }

        // Now convert remaining days into weeks + days if possible
        const weeks = Math.floor(days / 7);
        const remDays = days % 7;

        const parts = [];
        if (years > 0) parts.push(`${years} year${years !== 1 ? "s" : ""}`);
        if (months > 0) parts.push(`${months} month${months !== 1 ? "s" : ""}`);
        if (weeks > 0) parts.push(`${weeks} week${weeks !== 1 ? "s" : ""}`);
        if (remDays > 0 || parts.length === 0)
            parts.push(`${remDays} day${remDays !== 1 ? "s" : ""}`);

        let sentence = "";
        if (parts.length === 1) {
            sentence = parts[0];
        } else if (parts.length === 2) {
            sentence = `${parts[0]} and ${parts[1]}`;
        } else {
            const last = parts.pop();
            sentence = `${parts.join(", ")}, and ${last}`;
        }

        if (isReversed) {
            return `${sentence} ago`;
        }
        return sentence;
    }

    function calculate() {
        if (!startDateInput.value || !endDateInput.value) return;

        const start = parseLocalDate(startDateInput.value);
        const end = parseLocalDate(endDateInput.value);

        const isReversed = end.getTime() < start.getTime();

        const d1 = new Date(isReversed ? end : start);
        const d2 = new Date(isReversed ? start : end);

        const diffMs = d2.getTime() - d1.getTime();
        const totalDays = Math.round(diffMs / (1000 * 60 * 60 * 24));

        // Sign for negative outputs
        const sign = isReversed ? -1 : 1;

        // Standard days formatting
        resTotalDays.textContent = `${(totalDays * sign).toLocaleString()} day${totalDays !== 1 ? "s" : ""}`;

        // Weeks calculation
        const weeks = Math.floor(totalDays / 7);
        const remDays = totalDays % 7;
        resWeeksDays.textContent = `${(weeks * sign).toLocaleString()}w ${(remDays * sign).toLocaleString()}d`;

        // Mathematical averages for approximate months & years
        const approxMonths = (totalDays / 30.4368).toFixed(1);
        const approxYears = (totalDays / 365.2425).toFixed(1);

        resMonths.textContent = `${(parseFloat(approxMonths) * sign).toFixed(1)} month${parseFloat(approxMonths) !== 1 ? "s" : ""}`;
        resYears.textContent = `${(parseFloat(approxYears) * sign).toFixed(1)} year${parseFloat(approxYears) !== 1 ? "s" : ""}`;

        // Natural human sentence
        resSentence.textContent = getHumanReadableDiff(d1, d2, isReversed);

        resultsBlock.classList.remove("hidden");
    }

    form.addEventListener("submit", (e) => {
        e.preventDefault();
        calculate();
    });

    btnExample.addEventListener("click", () => {
        const today = new Date();
        const future = new Date();
        future.setFullYear(today.getFullYear() + 1);
        future.setMonth(today.getMonth() + 2);
        future.setDate(today.getDate() + 15); // ~1 year, 2 months, 15 days in the future

        const formatDate = (d: Date) => {
            const year = d.getFullYear();
            const month = String(d.getMonth() + 1).padStart(2, "0");
            const day = String(d.getDate()).padStart(2, "0");
            return `${year}-${month}-${day}`;
        };

        startDateInput.value = formatDate(today);
        endDateInput.value = formatDate(future);
        calculate();
    });

    btnClear.addEventListener("click", () => {
        form.reset();
        resultsBlock.classList.add("hidden");
    });

    btnCopy.addEventListener("click", () => {
        const textToCopy = `Calculation Results:
- Start Date: ${startDateInput.value}
- End Date: ${endDateInput.value}
- Summary: ${resSentence.textContent}
- Total Days: ${resTotalDays.textContent}
- Weeks breakdown: ${resWeeksDays.textContent}
- Approx Months: ${resMonths.textContent}
- Approx Years: ${resYears.textContent}`;

        navigator.clipboard.writeText(textToCopy).then(() => {
            const originalText = btnCopy.innerHTML;
            btnCopy.innerHTML = `
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5 text-green-600">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
        </svg>
        <span class="text-green-600">Copied!</span>
      `;
            setTimeout(() => {
                btnCopy.innerHTML = originalText;
            }, 2000);
        });
    });
</script>
