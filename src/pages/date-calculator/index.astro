---
import Layout from "../../layouts/Layout.astro";
---

<Layout
    title="Date Calculator - Count Days Between Dates"
    description="Calculate the exact number of days, weeks, and remaining days between two dates. Includes options for both including and excluding the end date."
>
    <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
        <!-- Breadcrumb -->
        <nav
            class="flex mb-8 text-sm font-medium text-slate-500"
            aria-label="Breadcrumb"
        >
            <ol class="inline-flex items-center space-x-1 md:space-x-3">
                <li class="inline-flex items-center">
                    <a href="/" class="hover:text-indigo-600 transition-colors"
                        >Home</a
                    >
                </li>
                <li>
                    <div class="flex items-center">
                        <svg
                            class="w-3 h-3 text-slate-400 mx-1"
                            aria-hidden="true"
                            xmlns="http://www.w3.org/2000/svg"
                            fill="none"
                            viewBox="0 0 6 10"
                        >
                            <path
                                stroke="currentColor"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="m1 9 4-4-4-4"></path>
                        </svg>
                        <span class="text-slate-400 ml-1 md:ml-2"
                            >Date Calculator</span
                        >
                    </div>
                </li>
            </ol>
        </nav>

        <!-- H1 Header -->
        <div class="border-b border-slate-200 pb-5 mb-8">
            <h1
                class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl"
            >
                Date Calculator
            </h1>
            <p class="mt-2 text-base text-slate-500">
                Calculate the duration between two dates in days, weeks, and
                weekdays.
            </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
            <!-- Calculator Column -->
            <div
                class="lg:col-span-7 bg-white rounded-2xl border border-slate-200 p-6 sm:p-8 shadow-sm"
            >
                <form id="calc-form" class="space-y-6">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                        <div>
                            <label
                                for="start-date"
                                class="block text-sm font-bold text-slate-700 mb-2"
                                >Start Date</label
                            >
                            <input
                                type="date"
                                id="start-date"
                                name="start-date"
                                class="block w-full rounded-xl border border-slate-300 px-4 py-3 text-slate-900 shadow-xs focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm"
                                required
                            />
                        </div>
                        <div>
                            <label
                                for="end-date"
                                class="block text-sm font-bold text-slate-700 mb-2"
                                >End Date</label
                            >
                            <input
                                type="date"
                                id="end-date"
                                name="end-date"
                                class="block w-full rounded-xl border border-slate-300 px-4 py-3 text-slate-900 shadow-xs focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm"
                                required
                            />
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="flex flex-wrap gap-3 pt-2">
                        <button
                            type="submit"
                            class="flex-1 min-w-[120px] rounded-xl bg-indigo-600 px-5 py-3 text-center text-sm font-bold text-white shadow-xs hover:bg-indigo-500 active:bg-indigo-700 transition-colors"
                        >
                            Calculate
                        </button>
                        <button
                            type="button"
                            id="btn-example"
                            class="rounded-xl border border-slate-200 bg-slate-50 px-5 py-3 text-sm font-semibold text-slate-700 hover:bg-slate-100 active:bg-slate-200 transition-colors"
                        >
                            Load Example
                        </button>
                        <button
                            type="button"
                            id="btn-clear"
                            class="rounded-xl border border-slate-200 bg-white px-5 py-3 text-sm font-semibold text-slate-500 hover:text-slate-700 hover:bg-slate-50 transition-colors"
                        >
                            Clear
                        </button>
                    </div>
                </form>

                <!-- Results Block -->
                <div
                    id="results-block"
                    class="hidden mt-8 border-t border-slate-100 pt-8 space-y-6"
                >
                    <div class="flex items-center justify-between">
                        <h2 class="text-lg font-bold text-slate-900">
                            Calculation Results
                        </h2>
                        <button
                            type="button"
                            id="btn-copy"
                            class="inline-flex items-center gap-1 text-xs font-semibold text-indigo-600 hover:text-indigo-500 border border-indigo-100 bg-indigo-50/50 hover:bg-indigo-50 px-2.5 py-1.5 rounded-lg transition-colors"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke-width="1.5"
                                stroke="currentColor"
                                class="w-3.5 h-3.5"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 0 1-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H5.25m11.9-3.664A2.251 2.251 0 0 0 15 2.25h-1.5a2.251 2.251 0 0 0-2.15 1.586m5.8 0c.065.21.1.433.1.664v.75h-6V4.5c0-.231.035-.454.1-.664M6.75 7.5H4.875c-.621 0-1.125.504-1.125 1.125v12c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V16.5a9 9 0 0 0-9-9Z"
                                ></path>
                            </svg>
                            <span>Copy results</span>
                        </button>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div
                            class="rounded-xl bg-slate-50 p-4 border border-slate-100"
                        >
                            <span
                                class="block text-xs font-medium text-slate-500 uppercase tracking-wider"
                                >Days (excluding end date)</span
                            >
                            <span
                                id="res-days-ex"
                                class="block mt-1 text-2xl font-extrabold text-indigo-600 font-mono-custom"
                                >-</span
                            >
                            <span class="block mt-1 text-xs text-slate-400"
                                >Standard calculation</span
                            >
                        </div>

                        <div
                            class="rounded-xl bg-slate-50 p-4 border border-slate-100"
                        >
                            <span
                                class="block text-xs font-medium text-slate-500 uppercase tracking-wider"
                                >Days (including end date)</span
                            >
                            <span
                                id="res-days-inc"
                                class="block mt-1 text-2xl font-extrabold text-indigo-600 font-mono-custom"
                                >-</span
                            >
                            <span class="block mt-1 text-xs text-slate-400"
                                >Total days inclusive</span
                            >
                        </div>

                        <div
                            class="rounded-xl bg-slate-50 p-4 border border-slate-100 sm:col-span-2"
                        >
                            <span
                                class="block text-xs font-medium text-slate-500 uppercase tracking-wider"
                                >Weeks and Days Breakdown</span
                            >
                            <span
                                id="res-weeks"
                                class="block mt-1 text-lg font-bold text-slate-800"
                                >-</span
                            >
                        </div>

                        <div
                            class="rounded-xl bg-slate-50 p-4 border border-slate-100"
                        >
                            <span
                                class="block text-xs font-medium text-slate-500 uppercase tracking-wider"
                                >Start Weekday</span
                            >
                            <span
                                id="res-start-day"
                                class="block mt-1 text-base font-semibold text-slate-700"
                                >-</span
                            >
                        </div>

                        <div
                            class="rounded-xl bg-slate-50 p-4 border border-slate-100"
                        >
                            <span
                                class="block text-xs font-medium text-slate-500 uppercase tracking-wider"
                                >End Weekday</span
                            >
                            <span
                                id="res-end-day"
                                class="block mt-1 text-base font-semibold text-slate-700"
                                >-</span
                            >
                        </div>
                    </div>
                </div>
            </div>

            <!-- Information Column -->
            <div class="lg:col-span-5 space-y-8">
                <!-- How to use -->
                <div
                    class="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm"
                >
                    <h2 class="text-lg font-bold text-slate-900 mb-4">
                        How to Use the Date Calculator
                    </h2>
                    <ol class="space-y-3 text-sm text-slate-600">
                        <li class="flex gap-2">
                            <span
                                class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-indigo-50 text-indigo-600 font-mono-custom font-bold text-xs"
                                >1</span
                            >
                            <span>Select the <strong>Start Date</strong>.</span>
                        </li>
                        <li class="flex gap-2">
                            <span
                                class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-indigo-50 text-indigo-600 font-mono-custom font-bold text-xs"
                                >2</span
                            >
                            <span>Select the <strong>End Date</strong>.</span>
                        </li>
                        <li class="flex gap-2">
                            <span
                                class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-indigo-50 text-indigo-600 font-mono-custom font-bold text-xs"
                                >3</span
                            >
                            <span
                                >Click <strong>Calculate</strong> to instantly view
                                results locally.</span
                            >
                        </li>
                    </ol>
                </div>

                <!-- Practical Example -->
                <div
                    class="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm"
                >
                    <h2 class="text-lg font-bold text-slate-900 mb-3">
                        Practical Example
                    </h2>
                    <p class="text-sm text-slate-600 leading-relaxed">
                        If you set the start date to <strong
                            >June 1, 2026</strong
                        > and the end date to <strong>June 15, 2026</strong>:
                    </p>
                    <ul
                        class="mt-2 space-y-1 text-sm text-slate-600 list-disc list-inside"
                    >
                        <li>
                            Calendar days between (excluding end date): <strong
                                >14 days</strong>
                        </li>
                        <li>
                            Calendar days between (including end date): <strong
                                >15 days</strong>
                        </li>
                        <li>In weeks: <strong>2 weeks and 0 days</strong></li>
                        <li>
                            Start weekday: <strong>Monday</strong>, End weekday: <strong
                                >Monday</strong>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Frequently Asked Questions -->
        <section class="mt-16 border-t border-slate-200 pt-16">
            <h2 class="text-2xl font-bold tracking-tight text-slate-900 mb-8">
                Frequently Asked Questions
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div>
                    <h3 class="text-base font-bold text-slate-900 mb-2">
                        What is the difference between including and excluding
                        the end date?
                    </h3>
                    <p class="text-sm text-slate-600 leading-relaxed">
                        Excluding the end date is the standard way of counting
                        duration (e.g., from Monday to Tuesday is 1 day).
                        Including the end date counts both calendar dates fully,
                        which is typical for lodging or billing stays (from
                        Monday to Tuesday is 2 inclusive days).
                    </p>
                </div>
                <div>
                    <h3 class="text-base font-bold text-slate-900 mb-2">
                        Are calculations performed securely?
                    </h3>
                    <p class="text-sm text-slate-600 leading-relaxed">
                        Yes, our date calculations are done completely on the
                        client side using standard JavaScript. No date values or
                        user information are transmitted to a backend,
                        guaranteeing full data privacy.
                    </p>
                </div>
                <div>
                    <h3 class="text-base font-bold text-slate-900 mb-2">
                        How are leap years calculated?
                    </h3>
                    <p class="text-sm text-slate-600 leading-relaxed">
                        Standard Gregorian leap rules are embedded in browser
                        JavaScript date calculations. Leap years like 2024 and
                        2028 are correctly counted as having 366 days, with 29
                        days in February.
                    </p>
                </div>
                <div>
                    <h3 class="text-base font-bold text-slate-900 mb-2">
                        Why would my results be off by an hour or a day?
                    </h3>
                    <p class="text-sm text-slate-600 leading-relaxed">
                        Our tool uses your browser's local timezone to calculate
                        durations. This completely avoids UTC date conversion
                        shifts, which are a common source of calculation errors
                        in date tools.
                    </p>
                </div>
            </div>
        </section>

        <!-- Related Tools Link -->
        <section
            class="mt-16 bg-slate-50 border border-slate-200/80 rounded-2xl p-8"
        >
            <h2 class="text-lg font-bold text-slate-900 mb-4">
                Related Calculators
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                <a
                    href="/business-days-calculator/"
                    class="flex items-center justify-between rounded-xl border border-slate-200 bg-white px-5 py-4 text-sm font-semibold text-slate-700 hover:text-indigo-600 hover:border-indigo-100 transition-all shadow-xs"
                >
                    <span>Business Days Calculator</span>
                    <span>&rarr;</span>
                </a>
                <a
                    href="/date-duration-calculator/"
                    class="flex items-center justify-between rounded-xl border border-slate-200 bg-white px-5 py-4 text-sm font-semibold text-slate-700 hover:text-indigo-600 hover:border-indigo-100 transition-all shadow-xs"
                >
                    <span>Date Duration Calculator</span>
                    <span>&rarr;</span>
                </a>
                <a
                    href="/weekdays-calculator/"
                    class="flex items-center justify-between rounded-xl border border-slate-200 bg-white px-5 py-4 text-sm font-semibold text-slate-700 hover:text-indigo-600 hover:border-indigo-100 transition-all shadow-xs"
                >
                    <span>Weekdays Calculator</span>
                    <span>&rarr;</span>
                </a>
            </div>
        </section>
    </div>
</Layout>

<script>
    const form = document.getElementById("calc-form") as HTMLFormElement;
    const startDateInput = document.getElementById(
        "start-date",
    ) as HTMLInputElement;
    const endDateInput = document.getElementById(
        "end-date",
    ) as HTMLInputElement;
    const resultsBlock = document.getElementById(
        "results-block",
    ) as HTMLDivElement;

    const resDaysEx = document.getElementById("res-days-ex") as HTMLSpanElement;
    const resDaysInc = document.getElementById(
        "res-days-inc",
    ) as HTMLSpanElement;
    const resWeeks = document.getElementById("res-weeks") as HTMLSpanElement;
    const resStartDay = document.getElementById(
        "res-start-day",
    ) as HTMLSpanElement;
    const resEndDay = document.getElementById("res-end-day") as HTMLSpanElement;

    const btnExample = document.getElementById(
        "btn-example",
    ) as HTMLButtonElement;
    const btnClear = document.getElementById("btn-clear") as HTMLButtonElement;
    const btnCopy = document.getElementById("btn-copy") as HTMLButtonElement;

    const weekdays = [
        "Sunday",
        "Monday",
        "Tuesday",
        "Wednesday",
        "Thursday",
        "Friday",
        "Saturday",
    ];

    function parseLocalDate(dateStr: string): Date {
        // Splits YYYY-MM-DD to construct local timezone dates (avoiding midnight UTC problems)
        const [year, month, day] = dateStr.split("-").map(Number);
        return new Date(year, month - 1, day);
    }

    function calculate() {
        if (!startDateInput.value || !endDateInput.value) return;

        const start = parseLocalDate(startDateInput.value);
        const end = parseLocalDate(endDateInput.value);

        // Calculate milliseconds difference
        const diffMs = end.getTime() - start.getTime();

        // One day in milliseconds (rounded to handle DST changes)
        const diffDays = Math.round(diffMs / (1000 * 60 * 60 * 24));

        // Exclusive calculation (standard days)
        const daysEx = diffDays;

        // Inclusive calculation (add 1 if end is after start or equal)
        const daysInc = diffDays >= 0 ? diffDays + 1 : diffDays - 1;

        // Weeks calculation
        const absDays = Math.abs(daysEx);
        const weeks = Math.floor(absDays / 7);
        const remDays = absDays % 7;
        const isPast = daysEx < 0;

        let weeksStr = "";
        if (isPast) {
            weeksStr = `${weeks} week${weeks !== 1 ? "s" : ""} and ${remDays} day${remDays !== 1 ? "s" : ""} ago`;
        } else {
            weeksStr = `${weeks} week${weeks !== 1 ? "s" : ""} and ${remDays} day${remDays !== 1 ? "s" : ""}`;
        }

        // Weekdays name
        const startWeekdayStr = weekdays[start.getDay()];
        const endWeekdayStr = weekdays[end.getDay()];

        // Output results
        resDaysEx.textContent = `${daysEx.toLocaleString()} day${Math.abs(daysEx) !== 1 ? "s" : ""}`;
        resDaysInc.textContent = `${daysInc.toLocaleString()} day${Math.abs(daysInc) !== 1 ? "s" : ""}`;
        resWeeks.textContent = weeksStr;
        resStartDay.textContent = startWeekdayStr;
        resEndDay.textContent = endWeekdayStr;

        resultsBlock.classList.remove("hidden");
    }

    form.addEventListener("submit", (e) => {
        e.preventDefault();
        calculate();
    });

    btnExample.addEventListener("click", () => {
        // Current date as start date
        const today = new Date();
        const future = new Date();
        future.setDate(today.getDate() + 14); // 2 weeks in future

        const formatDate = (d: Date) => {
            const year = d.getFullYear();
            const month = String(d.getMonth() + 1).padStart(2, "0");
            const day = String(d.getDate()).padStart(2, "0");
            return `${year}-${month}-${day}`;
        };

        startDateInput.value = formatDate(today);
        endDateInput.value = formatDate(future);
        calculate();
    });

    btnClear.addEventListener("click", () => {
        form.reset();
        resultsBlock.classList.add("hidden");
    });

    btnCopy.addEventListener("click", () => {
        const textToCopy = `Calculation Results:
- Start Date: ${startDateInput.value} (${resStartDay.textContent})
- End Date: ${endDateInput.value} (${resEndDay.textContent})
- Days excluding end date: ${resDaysEx.textContent}
- Days including end date: ${resDaysInc.textContent}
- Weeks breakdown: ${resWeeks.textContent}`;

        navigator.clipboard.writeText(textToCopy).then(() => {
            const originalText = btnCopy.innerHTML;
            btnCopy.innerHTML = `
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5 text-green-600">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
        </svg>
        <span class="text-green-600">Copied!</span>
      `;
            setTimeout(() => {
                btnCopy.innerHTML = originalText;
            }, 2000);
        });
    });
</script>
