---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

export async function getStaticPaths() {
    const posts = await getCollection("blog");
    return posts.map((post: CollectionEntry<"blog">) => ({
        params: { slug: post.slug },
        props: { post },
    }));
}

interface Props {
    post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<Layout
    title={`${post.data.title} - Date Calculator Tools`}
    description={post.data.description}
>
    <!-- Main layout container -->
    <article class="mx-auto max-w-4xl px-4 py-12 sm:px-6 lg:px-8">
        <!-- Breadcrumb -->
        <nav
            class="flex mb-8 text-sm font-medium text-slate-500"
            aria-label="Breadcrumb"
        >
            <ol class="inline-flex items-center space-x-1 md:space-x-3">
                <li class="inline-flex items-center">
                    <a href="/" class="hover:text-indigo-600 transition-colors"
                        >Home</a
                    >
                </li>
                <li>
                    <div class="flex items-center">
                        <svg
                            class="w-3 h-3 text-slate-400 mx-1"
                            aria-hidden="true"
                            xmlns="http://www.w3.org/2000/svg"
                            fill="none"
                            viewBox="0 0 6 10"
                        >
                            <path
                                stroke="currentColor"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="m1 9 4-4-4-4"></path>
                        </svg>
                        <a
                            href="/blog/"
                            class="hover:text-indigo-600 transition-colors ml-1 md:ml-2"
                            >Blog</a
                        >
                    </div>
                </li>
                <li>
                    <div class="flex items-center">
                        <svg
                            class="w-3 h-3 text-slate-400 mx-1"
                            aria-hidden="true"
                            xmlns="http://www.w3.org/2000/svg"
                            fill="none"
                            viewBox="0 0 6 10"
                        >
                            <path
                                stroke="currentColor"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="m1 9 4-4-4-4"></path>
                        </svg>
                        <span
                            class="text-slate-400 ml-1 md:ml-2 truncate max-w-[200px] sm:max-w-none"
                            >{post.data.title}</span
                        >
                    </div>
                </li>
            </ol>
        </nav>

        <!-- Header section -->
        <header class="pb-8 border-b border-slate-200">
            <div class="flex items-center gap-2 mb-4">
                <time
                    datetime={post.data.date}
                    class="text-xs font-semibold text-slate-400 font-mono-custom"
                >
                    {post.data.date}
                </time>
                <span class="text-slate-300">•</span>
                <span
                    class="text-xs font-semibold text-indigo-600 uppercase tracking-wider"
                    >Guide</span
                >
            </div>
            <h1
                class="text-3xl sm:text-4xl font-extrabold tracking-tight text-slate-900 leading-tight"
            >
                {post.data.title}
            </h1>
            <p class="mt-4 text-base text-slate-500 italic leading-relaxed">
                {post.data.description}
            </p>
        </header>

        <!-- Markdown Content Area -->
        <div
            class="prose prose-indigo max-w-none py-10 text-slate-700 leading-relaxed space-y-6"
        >
            <Content />
        </div>

        <!-- Related Tool Promotion Card -->
        {
            post.data.relatedToolLink && (
                <div class="my-12 rounded-2xl bg-gradient-to-r from-indigo-50 to-indigo-100/50 p-6 sm:p-8 border border-indigo-100 shadow-sm flex flex-col sm:flex-row items-center justify-between gap-6">
                    <div class="space-y-2">
                        <span class="text-xs font-bold text-indigo-600 uppercase tracking-widest font-mono-custom">
                            Interactive Tool Solution
                        </span>
                        <h3 class="text-lg font-extrabold text-indigo-950">
                            Calculate this instantly with the{" "}
                            {post.data.relatedToolName}!
                        </h3>
                        <p class="text-sm text-indigo-800 leading-relaxed">
                            Don't get bogged down in manual calculations. Use
                            our secure, responsive tool to get accurate counts
                            in seconds.
                        </p>
                    </div>
                    <a
                        href={post.data.relatedToolLink}
                        class="w-full sm:w-auto shrink-0 inline-flex items-center justify-center rounded-xl bg-indigo-600 px-5 py-3 text-sm font-bold text-white shadow-md hover:bg-indigo-500 active:bg-indigo-700 transition-colors"
                    >
                        Open {post.data.relatedToolName}
                    </a>
                </div>
            )
        }

        <!-- Navigation Footer -->
        <div
            class="mt-12 border-t border-slate-200 pt-8 flex items-center justify-between"
        >
            <a
                href="/blog/"
                class="inline-flex items-center gap-1 text-sm font-bold text-indigo-600 hover:text-indigo-500 transition-colors"
            >
                &larr; Back to all guides
            </a>
            <a
                href="/"
                class="inline-flex items-center gap-1 text-sm font-bold text-slate-600 hover:text-indigo-600 transition-colors"
            >
                Go to Homepage &rarr;
            </a>
        </div>
    </article>
</Layout>

<!-- Simple style override to style standard Markdown elements beautifully inside Astro without heavy tailwind plugins -->
<style is:global>
    .prose h1 {
        display: none; /* Already using the manual H1 in the header */
    }
    .prose h2 {
        font-size: 1.5rem;
        font-weight: 800;
        color: #0f172a; /* Slate 900 */
        margin-top: 2.5rem;
        margin-bottom: 1rem;
        letter-spacing: -0.025em;
    }
    .prose h3 {
        font-size: 1.25rem;
        font-weight: 700;
        color: #1e293b; /* Slate 800 */
        margin-top: 2rem;
        margin-bottom: 0.75rem;
    }
    .prose p {
        margin-bottom: 1.5rem;
        font-size: 1rem;
        line-height: 1.75;
    }
    .prose ul,
    .prose ol {
        margin-top: 1rem;
        margin-bottom: 1.5rem;
        padding-left: 1.5rem;
    }
    .prose ul {
        list-style-type: disc;
    }
    .prose ol {
        list-style-type: decimal;
    }
    .prose li {
        margin-bottom: 0.5rem;
        line-height: 1.625;
    }
    .prose hr {
        margin: 2.5rem 0;
        border: 0;
        border-top: 1px solid #e2e8f0; /* Slate 200 */
    }
    .prose table {
        width: 100%;
        border-collapse: collapse;
        margin: 1.5rem 0;
        font-size: 0.875rem;
    }
    .prose th,
    .prose td {
        border: 1px solid #e2e8f0;
        padding: 0.75rem 1rem;
        text-align: left;
    }
    .prose th {
        background-color: #f8fafc;
        font-weight: 700;
        color: #0f172a;
    }
    .prose blockquote {
        border-left: 4px solid #4f46e5;
        padding-left: 1.25rem;
        color: #475569;
        font-style: italic;
        margin: 1.5rem 0;
    }
    .prose strong {
        font-weight: 700;
        color: #0f172a;
    }
    .prose code {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.875em;
        background-color: #f1f5f9;
        color: #0f172a;
        padding: 0.2rem 0.4rem;
        border-radius: 0.375rem;
        font-weight: 500;
    }
</style>
